generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  CREATED
  ANALYZED
  FOLLOW_UP_COMPLETED
  DOCUMENTS_GENERATED
}

enum WorkflowStage {
  PARSE_SOURCE
  EXTRACT_CANDIDATE
  EXTRACT_JOB
  DETECT_GAP
  GENERATE_FOLLOW_UP
  REGENERATE_CANDIDATE
  GENERATE_DRAFTS
  GENERATE_INTERVIEW
  REWRITE_FOR_JOB
}

model Application {
  id                   Int               @id @default(autoincrement())
  testUserId           String?
  testUser             TestUser?         @relation(fields: [testUserId], references: [id], onDelete: SetNull)
  status               ApplicationStatus @default(CREATED)
  /// 사용자 지정 워크플로우 이름(표시용)
  title                String?
  resumeText           String
  portfolioText        String
  projectDescriptions  String[]
  targetJobPostingText String
  candidateProfileJson Json?
  jobPostingJson       Json?
  gapAnalysisJson      Json?
  fitAnalysisJson      Json?
  followUpQuestions    String[]
  followUpAnswersJson  Json?
  generatedDraftJson   Json?
  rewrittenDraftJson   Json?
  /// 면접 대비 리포트 보면서 남긴 사용자 메모(질문별)
  interviewNotesJson   Json?
  workflowRuns         WorkflowRun[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([testUserId, createdAt])
}

model WorkflowRun {
  id            Int           @id @default(autoincrement())
  applicationId Int
  stage         WorkflowStage
  inputJson     Json?
  outputJson    Json?
  errorMessage  String?
  createdAt     DateTime      @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, stage])
}

model TestUser {
  id           String        @id
  applications Application[]
  createdAt    DateTime      @default(now())
}

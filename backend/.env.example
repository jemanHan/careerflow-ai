NODE_ENV=development
PORT=4000
CORS_ORIGIN="http://localhost:3000"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careerflow_ai?schema=public"
LLM_PROVIDER="gemini"
GEMINI_API_KEY=""
# 리라이트 등 보조 단계(light). 문서·면접은 HIGH_QUALITY 사용.
GEMINI_DEFAULT_MODEL="gemini-2.5-flash-lite"
# 문서 생성·면접 리포트·재분석 시 추출/갭/보완 질문(최초 이후)
GEMINI_HIGH_QUALITY_MODEL="gemini-2.5-flash"
# 공고 대비 분석 파이프라인 4단계(후보·공고·갭·후속질문): 매 `analysis/run`마다 사용. 미설정 시 light/quality 라우트만 사용
# 예: gemini-2.5-pro (모델명은 Google AI Studio 기준으로 조정)
GEMINI_PREMIUM_MODEL=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_HIGH_QUALITY_MODEL="gpt-4.1"
OPENAI_TEMPERATURE=0.2

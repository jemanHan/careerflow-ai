NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careerflow_ai?schema=public"
LLM_PROVIDER="gemini"
GEMINI_API_KEY=""
# 경량: 추출·JD·갭·후속·면접 질문 (무료 티어는 모델별 일일 한도가 있음 — 필요 시 .env에서만 조정)
GEMINI_DEFAULT_MODEL="gemini-3.1-flash-lite"
# 고품질: 문서 3종 생성·JD 맞춤 리라이트만
GEMINI_HIGH_QUALITY_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_HIGH_QUALITY_MODEL="gpt-4.1"
OPENAI_TEMPERATURE=0.2
